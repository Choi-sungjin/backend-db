PORT=5000

# MongoDB 연결 주소 (로컬 또는 Atlas)
# 로컬 개발용 예시:
# MONGO_URI=mongodb://127.0.0.1:27017/todo-backend
#
# Atlas 예시 (주의: 실제 비밀번호는 .env에만 넣고, git에는 올리지 마세요)
# MONGO_URI=mongodb+srv://<사용자>:<비밀번호>@<클러스터주소>/todo-backend?retryWrites=true&w=majority
MONGO_URI=

# CORS 허용 Origin 목록 (쉼표로 구분)
# 예시:
# CORS_ORIGINS=http://localhost:5173,https://<vercel-domain>
CORS_ORIGINS=

